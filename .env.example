# MySQL root 密码，只给 MySQL 容器首次初始化和健康检查使用。
MYSQL_ROOT_PASSWORD=change-me-root-password
# MySQL 容器首次初始化时自动创建的业务库名。
MYSQL_DATABASE=aigen_studio
# MySQL 容器首次初始化时自动创建的业务用户。
MYSQL_USERNAME=aigen_app
# MySQL 容器首次初始化时设置的业务用户密码，需要与 application-prod.yml 保持一致。
MYSQL_PASSWORD=change-me-db-password
# 宿主机暴露 MySQL 的端口，Navicat 直连服务器数据库时会用到。
MYSQL_HOST_PORT=3306

# 宿主机暴露网站入口的端口，默认 80。
WEB_HTTP_PORT=80
